        <h4>Input</h4>
        <a href="#key-input">Key Input</a>
        <a href="#touch-input">Touch Input</a>

        <h4>Apps</h4>
        <a href="#app-lifecycle">App Lifecycle</a>

        <h4>Queries</h4>
        <a href="#queries">Device Queries</a>

        <h4>Dev Tools</h4>
        <a href="#sideload-screenshot">Sideload & Screenshot</a>
        <a href="#debug-console">Debug Console</a>

