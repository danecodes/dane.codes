  accentColor="#3fb950"
  accentColorBright="#56d364"
  basePath="/roku-ecp"
  navLinks={[
    { label: 'Docs', href: '/roku-ecp/docs' },
  ]}
  githubUrl="https://github.com/danecodes/roku-ecp"
  npmUrl="https://www.npmjs.com/package/@danecodes/roku-ecp"
>
  <div class="docs-layout">
    <aside class="docs-sidebar">
      <nav>
        <h4>Getting Started</h4>
        <a href="#install">Installation</a>
        <a href="#quick-start">Quick Start</a>

