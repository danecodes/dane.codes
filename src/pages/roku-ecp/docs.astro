        <a href="#ui-tree">Parsing & Querying</a>
        <a href="#selectors">Selector Syntax</a>
        <a href="#ui-node">UiNode Interface</a>

        <h4>Wait Helpers</h4>
        <a href="#wait-helpers">Wait Helpers</a>

        <h4>Error Handling</h4>
        <a href="#typed-errors">Typed Errors</a>

        <h4>Log Parsing</h4>
        <a href="#console-parser">Console Parser</a>
        <a href="#structured-logs">Structured Log Parsing</a>

