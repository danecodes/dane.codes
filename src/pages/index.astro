---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
).slice(0, 3);

const featured = [
  { title: 'roku-mcp', description: 'MCP server for AI agents to interact with Roku devices — inspect SceneGraph UI, send remote input, take screenshots, query device state.', tech: ['TypeScript', 'MCP', 'Roku'], url: '/roku-mcp' },
  { title: 'rokuperf', description: 'CLI profiling tool for Roku channels — live metrics, SceneGraph diffing, BrightScript console.', tech: ['TypeScript', 'CLI', 'Roku'], url: 'https://github.com/danecodes/rokuperf' },
  { title: 'botcall-mcp', description: 'An MCP server that gives AI agents real phone numbers. Provision a number, receive SMS, and extract verification codes.', tech: ['JavaScript', 'MCP', 'SMS'], url: 'https://github.com/danecodes/botcall-mcp' },
];
---

<BaseLayout title="Home" description="Dane Hesseldahl — Senior Roku Developer & OTT Streaming Engineer at Crunchyroll. 25+ years building TV platform experiences with BrightScript, SceneGraph, and connected TV tech. Previously Hulu, Disney Streaming.">
  <section class="hero">
    <div class="container">
      <h1>Dane Hesseldahl</h1>
      <p class="hero-sub">Senior Roku developer and OTT engineer building streaming TV platform experiences for millions. Currently at Crunchyroll. Previously Disney Streaming, Hulu, Nordstrom. 25+ years shipping code for the web and the living room.</p>
      <div class="hero-cta">
        <a href="/projects" class="btn btn-primary">View Projects</a>
        <a href="/blog" class="btn btn-surface">Read the Blog</a>
      </div>
    </div>
  </section>

  <section class="recent-projects">
    <div class="container">
      <h2>Featured Projects</h2>
      <div class="project-grid">
        {featured.map((project) => (
          <a href={project.url} class="card project-card" target="_blank" rel="noopener">
            <h5>{project.title}</h5>
            <p>{project.description}</p>
            <div class="tech-tags">
              {project.tech.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
      <div class="see-all">
        <a href="/projects" class="btn btn-surface">All Projects</a>
      </div>
    </div>
  </section>

  <section class="latest-posts">
    <div class="container">
      <h2>Latest Posts</h2>
      {posts.length === 0 ? (
        <p class="section-note">Blog posts will appear here once you start writing.</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-item">
              <h5>{post.data.title}</h5>
              {post.data.description && <p>{post.data.description}</p>}
            </a>
          ))}
        </div>
      )}
      <a href="/blog" class="btn btn-surface">All Posts</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 120px 0 100px;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
  }

  .hero h1 {
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-text-muted);
    margin-bottom: 40px;
    max-width: 560px;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .recent-projects h2,
  .latest-posts h2 {
    margin-bottom: 40px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .project-card {
    display: block;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    color: var(--color-text);
    border-color: var(--color-orange);
  }

  .project-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .tech-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    background: var(--color-surface-raised);
    color: var(--color-sunshine-500);
    border: 1px solid var(--color-border);
  }

  .see-all {
    margin-top: 32px;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 32px;
  }

  .post-item {
    display: block;
    padding: 20px 24px;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s ease;
    border-left: 2px solid transparent;
  }

  .post-item:hover {
    background: var(--color-surface);
    border-left-color: var(--color-orange);
    color: var(--color-text);
  }

  .post-item time {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .post-item h5 {
    margin: 4px 0;
  }

  .post-item p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .section-note {
    color: var(--color-text-muted);
    margin-bottom: 24px;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 80px 0 60px;
    }
  }
</style>
