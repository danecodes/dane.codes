    padding: 4px 0;
    transition: color 0.15s;
  }

  .docs-sidebar a:hover { color: #fff; }

  .docs-content { min-width: 0; }

  .docs-content h1 { margin-bottom: 8px; }
  .docs-intro { color: var(--uj-text-muted); font-size: 1.125rem; margin-bottom: 48px; }

  .docs-content section { margin-bottom: 56px; }
  .docs-content section h2 { margin-bottom: 16px; padding-top: 24px; }
  .docs-content section h3 { margin: 24px 0 12px; color: var(--uj-accent); }
  .docs-content p { color: var(--uj-text-muted); margin-bottom: 12px; }

  .docs-content ul {
    color: var(--uj-text-muted);
    padding-left: 24px;
