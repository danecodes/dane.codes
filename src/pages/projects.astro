---
import BaseLayout from '../layouts/BaseLayout.astro';

const repos = [
  {
    title: 'roku-mcp',
    description: 'MCP server and CLI for AI agents to interact with Roku devices — inspect SceneGraph UI, send remote input, take screenshots, query device state. No WebDriver, no Java, just HTTP.',
    tech: ['TypeScript', 'MCP', 'Roku'],
    url: 'https://github.com/danecodes/roku-mcp',
    stars: 3,
  },
  {
    title: 'roku-ecp',
    description: 'TypeScript client for the Roku External Control Protocol (ECP).',
    tech: ['TypeScript', 'Roku', 'ECP'],
    url: 'https://github.com/danecodes/roku-ecp',
  },
  {
    title: 'rokuperf',
    description: 'CLI profiling tool for Roku channels — live metrics, SceneGraph diffing, BrightScript console.',
    tech: ['TypeScript', 'CLI', 'Roku'],
    url: 'https://github.com/danecodes/rokuperf',
  },
  {
    title: 'roku-screenshot',
    description: 'Capture, diff, and process screenshots from Roku devices.',
    tech: ['TypeScript', 'Roku', 'Image Processing'],
    url: 'https://github.com/danecodes/roku-screenshot',
  },
  {
    title: 'botcall',
    description: 'Phone numbers for AI agents. Dead simple. Get an API key, get a number, receive verification codes. Handles all the Twilio/SignalWire complexity so you don\'t have to.',
    tech: ['TypeScript', 'CLI', 'SMS'],
    url: 'https://github.com/danecodes/botcall',
  },
  {
    title: 'botcall-mcp',
    description: 'MCP server wrapper for botcall. Gives AI agents real phone numbers through tool calls — provision a number, receive SMS, extract verification codes.',
    tech: ['JavaScript', 'MCP', 'SMS'],
    url: 'https://github.com/danecodes/botcall-mcp',
  },
  {
    title: 'uncle-jesse',
    description: 'E2E testing framework for smart TVs. TypeScript, off-device, over HTTP. Roku first. No Appium, no WebdriverIO, no Selenium Grid, no Java — just Node and HTTP requests to the device.',
    tech: ['TypeScript', 'Roku', 'Testing', 'ECP'],
    url: 'https://github.com/danecodes/uncle-jesse',
  },
  {
    title: 'eyeballs',
    description: 'Visual monitoring for AI agents and humans. CLI + MCP server.',
    tech: ['TypeScript', 'MCP', 'CLI'],
    url: 'https://github.com/danecodes/eyeballs',
  },
];

const career = [
  {
    title: 'Crunchyroll — Roku App',
    description: 'Senior engineer on the Roku team, shaping the streaming experience for millions of anime fans worldwide. Performance, accessibility, and great TV UI.',
    tech: ['Roku', 'BrightScript', 'SceneGraph'],
    period: '2024 — Present',
  },
  {
    title: 'Disney Streaming — Design Engineering',
    description: 'Internal tooling and systems bridging design and engineering across Disney+, Hulu, and other high-profile products.',
    tech: ['React', 'Design Systems', 'Tooling'],
    period: '2022 — 2023',
  },
  {
    title: 'Hulu — Living Room & TV Platforms',
    description: 'Built and led the team creating Hulu clients for Xbox, PlayStation, Apple TV, Roku, FireTV, and more. Led optimization & experimentation across the platform.',
    tech: ['JavaScript', 'TV Platforms', 'A/B Testing'],
    period: '2013 — 2022',
  },
];
---

<BaseLayout title="Projects" description="Open source Roku developer tools, BrightScript & SceneGraph utilities, MCP servers, and a career of OTT streaming TV platform engineering at Crunchyroll, Hulu, and Disney.">
  <section class="page-header">
    <div class="container">
      <h1>Projects</h1>
      <p class="page-sub">Open source tools and a decade of building for the living room.</p>
    </div>
  </section>

  <section class="oss-section">
    <div class="container">
      <h2>Open Source</h2>
      <div class="project-grid">
        {repos.map((repo) => (
          <a href={repo.url} class="card project-card" target="_blank" rel="noopener">
            <div class="repo-header">
              <h5>{repo.title}</h5>
              {repo.stars && <span class="stars">{repo.stars}</span>}
            </div>
            <p>{repo.description}</p>
            <div class="tech-tags">
              {repo.tech.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="career-section">
    <div class="container">
      <h2>Career Highlights</h2>
      <div class="project-grid">
        {career.map((project) => (
          <div class="card project-card">
            <span class="project-period">{project.period}</span>
            <h5>{project.title}</h5>
            <p>{project.description}</p>
            <div class="tech-tags">
              {project.tech.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 100px 0 60px;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
  }

  .page-sub {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin-top: 12px;
  }

  .oss-section {
    padding-top: 48px;
  }

  .career-section h2,
  .oss-section h2 {
    margin-bottom: 32px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .project-card {
    display: block;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  a.project-card:hover {
    transform: translateY(-4px);
    color: var(--color-text);
    border-color: var(--color-orange);
  }

  .repo-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }

  .repo-header h5 {
    margin-bottom: 0;
  }

  .stars::before {
    content: '\2605 ';
  }

  .stars {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-sunshine-500);
  }

  .project-period {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-muted);
    margin-bottom: 8px;
    display: block;
  }

  .project-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .tech-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    background: var(--color-surface-raised);
    color: var(--color-sunshine-500);
    border: 1px solid var(--color-border);
  }
</style>
