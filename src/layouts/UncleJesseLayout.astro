---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Uncle Jesse — E2E testing framework for smart TVs. TypeScript, off-device, over HTTP. No Appium, no Selenium, no Java.' } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, 'https://dane.codes').href;
const siteTitle = `${title} — Uncle Jesse`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Roku testing, E2E testing, smart TV testing, BrightScript, SceneGraph, TV automation, Roku developer tools, test framework, TypeScript, ECP, connected TV, OTT testing" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Uncle Jesse" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{siteTitle}</title>
  </head>
  <body>
    <nav>
      <div class="uj-container nav-inner">
        <a href="/uncle-jesse" class="nav-logo">
          <span class="logo-icon">UJ</span>
          <span>Uncle Jesse</span>
        </a>
        <div class="nav-links">
          <a href="/uncle-jesse/docs" class:list={[{ active: currentPath.startsWith('/uncle-jesse/docs') }]}>Docs</a>
          <a href="/uncle-jesse/migration" class:list={[{ active: currentPath.startsWith('/uncle-jesse/migration') }]}>Migration</a>
          <a href="https://github.com/danecodes/uncle-jesse" target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.npmjs.com/package/@danecodes/uncle-jesse-core" target="_blank" rel="noopener">npm</a>
        </div>
        <button class="nav-toggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="uj-container footer-inner">
        <p>Uncle Jesse is open source under the MIT License.</p>
        <p class="footer-sub">Built by <a href="/">dane.codes</a> — part of the <a href="https://github.com/danecodes">@danecodes</a> Roku toolchain.</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => links?.classList.toggle('open'));
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --uj-bg: #0b0d0f;
    --uj-surface: #12151a;
    --uj-surface-raised: #1a1e25;
    --uj-border: #252a33;
    --uj-text: #e1e4e8;
    --uj-text-muted: #8b949e;
    --uj-accent: #58a6ff;
    --uj-accent-bright: #79c0ff;
    --uj-green: #3fb950;
    --uj-orange: #d29922;
    --uj-red: #f85149;
    --uj-purple: #bc8cff;
    --uj-max-width: 1200px;
    --uj-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --uj-mono: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
  }

  html { scroll-behavior: smooth; color-scheme: dark; }

  body {
    font-family: var(--uj-font);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.6;
    color: var(--uj-text);
    background: var(--uj-bg);
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--uj-font);
    font-weight: 600;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.1; }
  h2 { font-size: clamp(1.75rem, 3vw, 2.25rem); line-height: 1.2; }
  h3 { font-size: 1.375rem; line-height: 1.3; }
  h4 { font-size: 1.125rem; line-height: 1.4; }

  a { color: var(--uj-accent); text-decoration: none; transition: color 0.15s; }
  a:hover { color: var(--uj-accent-bright); }

  code {
    font-family: var(--uj-mono);
    font-size: 0.875rem;
    background: var(--uj-surface-raised);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--uj-border);
  }

  pre {
    background: var(--uj-surface);
    border: 1px solid var(--uj-border);
    border-radius: 8px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 16px 0;
    font-family: var(--uj-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  pre code { background: none; padding: 0; border: none; border-radius: 0; }

  .uj-container { max-width: var(--uj-max-width); margin: 0 auto; padding: 0 24px; }

  table { width: 100%; border-collapse: collapse; margin: 24px 0; font-size: 0.9375rem; }
  th { text-align: left; font-weight: 600; color: #fff; padding: 12px 16px; border: 1px solid var(--uj-border); background: var(--uj-surface); }
  td { padding: 12px 16px; border: 1px solid var(--uj-border); color: var(--uj-text-muted); }
  td code { font-size: 0.8125rem; }
  tr:hover td { background: var(--uj-surface); }
</style>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11, 13, 15, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--uj-border);
    padding: 12px 0;
  }

  .nav-inner { display: flex; align-items: center; justify-content: space-between; }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 1.125rem;
    color: #fff;
  }

  .nav-logo:hover { color: var(--uj-accent); }

  .logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--uj-accent);
    color: var(--uj-bg);
    font-family: var(--uj-mono);
    font-weight: 700;
    font-size: 0.75rem;
    border-radius: 6px;
  }

  .nav-links { display: flex; gap: 28px; }

  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--uj-text-muted);
    transition: color 0.15s;
  }

  .nav-links a:hover, .nav-links a.active { color: #fff; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span { display: block; width: 20px; height: 2px; background: var(--uj-text); }

  footer {
    padding: 48px 0;
    border-top: 1px solid var(--uj-border);
    text-align: center;
  }

  .footer-inner p { font-size: 0.875rem; color: var(--uj-text-muted); }
  .footer-sub { margin-top: 4px; font-size: 0.8125rem; }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--uj-surface);
      border: 1px solid var(--uj-border);
      padding: 20px;
      gap: 16px;
    }
    .nav-links.open { display: flex; }
    .nav-toggle { display: flex; }
  }
</style>
