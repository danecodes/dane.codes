---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Dane Hesseldahl — Senior Roku Developer & OTT Engineer with 25+ years experience building streaming TV platforms at Crunchyroll, Hulu, and Disney. BrightScript, SceneGraph, connected TV, engineering leadership.' } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, 'https://danecodes.com').href;
const siteTitle = `${title} — Dane Hesseldahl | Roku & OTT Streaming Engineer`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Dane Hesseldahl",
  "url": "https://danecodes.com",
  "jobTitle": "Senior Software Engineer — Roku",
  "worksFor": {
    "@type": "Organization",
    "name": "Crunchyroll"
  },
  "knowsAbout": [
    "Roku", "BrightScript", "SceneGraph", "OTT", "CTV", "Connected TV",
    "Streaming", "TV Platforms", "Living Room Platforms", "Smart TV Development",
    "TypeScript", "JavaScript", "React", "Design Systems", "Engineering Leadership",
    "A/B Testing", "MCP Servers", "Node.js"
  ],
  "sameAs": [
    "https://github.com/danecodes",
    "https://www.linkedin.com/in/daneh/"
  ],
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "Oregon Institute of Technology"
  }
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="keywords" content="Roku developer, OTT engineer, streaming engineer, TV platform engineer, BrightScript, SceneGraph, connected TV, CTV, living room platforms, senior software engineer, engineering leader, Crunchyroll, Hulu, Disney Streaming, smart TV development" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="danecodes.com" />
    <meta property="og:image" content="https://danecodes.com/favicon.svg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://danecodes.com/favicon.svg" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <title>{siteTitle}</title>
  </head>
  <body>
    <nav>
      <div class="container nav-inner">
        <a href="/" class="nav-logo">danecodes</a>
        <div class="nav-links">
          <a href="/projects" class:list={[{ active: currentPath.startsWith('/projects') }]}>Projects</a>
          <a href="/blog" class:list={[{ active: currentPath.startsWith('/blog') }]}>Blog</a>
          <a href="/resume" class:list={[{ active: currentPath.startsWith('/resume') }]}>Resume</a>
          <a href="/contact" class:list={[{ active: currentPath.startsWith('/contact') }]}>Contact</a>
        </div>
        <button class="nav-toggle" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container footer-inner">
        <p>&copy; {new Date().getFullYear()} danecodes.com</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        links?.classList.toggle('open');
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 15, 15, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 16px 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-ivory);
  }

  .nav-logo:hover {
    color: var(--color-orange);
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-muted);
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-orange);
    transition: width 0.2s ease;
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: transform 0.2s ease;
  }

  footer {
    padding: 48px 0;
    background: var(--color-surface);
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      padding: 24px;
      gap: 20px;
      box-shadow: var(--shadow-golden);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-toggle {
      display: flex;
    }
  }
</style>
